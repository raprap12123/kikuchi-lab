{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.{html,css,js,png,jpg,svg,ico}",
      "use": "@vercel/static",
      "config": {
        "excludeFiles": ["api/**", "node_modules/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" }
  ],
  "env": {
    "DEMO_MODE": "true"
  }
}
